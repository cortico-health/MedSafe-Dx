.venv
healthbench
.claude
# Ignore everything under results/ except the two analysis markdown files
# served by the deployed site (/publish-tables.html, /case-breakdown.html).
# Raw artifacts, predictions, and other analysis notes stay ignored.
results/*
!results/analysis/
results/analysis/*
!results/analysis/publish_tables.md
!results/analysis/case_breakdown_tables.md

# Raw data files (prevent gaming)
data/ddxplus_v0
data/test_sets
data/section111_valid_icd10_october2025.xlsx

# Generated test sets (user-created with seeds)
# Can be force-added with `git add -f` if needed for versioning
data/test_sets/

# Environment variables
.env
.env.local

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# LaTeX build outputs
*.aux
*.bbl
*.blg
*.log
*.out
*.pdf
*.synctex.gz

# OS
.DS_Store
Thumbs.db

